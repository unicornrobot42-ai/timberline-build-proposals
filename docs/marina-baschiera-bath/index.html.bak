<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Timberline Build Co — Bathroom Remodel | 609 E Avenida San Juan</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green:  #19412c;
      --brown:  #614432;
      --dark:   #312509;
      --navy:   #213245;
      --gold:   #e9af3b;
      --cream:  #f9f6f1;
      --light:  #fdfcfa;
      --border: #e5e0d8;
      /* US Letter at 96dpi = 816 × 1056px */
      --pw: 816px;
      --ph: 1056px;
    }

    html, body {
      font-family: 'Montserrat', sans-serif;
      background: #888;
      color: #1a1a1a;
      -webkit-font-smoothing: antialiased;
      margin: 0;
      padding: 0;
    }

    /* ── EACH PAGE IS EXACTLY 816 × 1056 px ── */
    .page {
      width: var(--pw);
      height: var(--ph);
      overflow: hidden;
      position: relative;
      margin: 0 auto;
      background: white;
      display: flex;
      flex-direction: column;
    }

    /* Screen preview spacing */
    @media screen {
      .page { margin: 16px auto; box-shadow: 0 4px 32px rgba(0,0,0,0.35); }
    }

    /* Print: each .page = exactly one PDF page */
    @media print {
      @page { size: letter; margin: 0; }
      html, body { background: white; }
      .page {
        page-break-after: always;
        break-after: page;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .page:last-child { page-break-after: auto; break-after: auto; }
    }

    /* ─────────── SHARED ATOMS ─────────── */
    .label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 10px;
    }
    .title {
      font-size: 28px;
      font-weight: 800;
      line-height: 1.15;
      color: var(--green);
      margin-bottom: 20px;
    }
    .title-light { color: white; }
    .gold-bar {
      width: 48px; height: 3px;
      background: var(--gold);
      margin-bottom: 28px;
    }

    /* ─────────── PAGE 1 · COVER ─────────── */
    .cover {
      background: var(--green);
      color: white;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 56px 72px;
    }
    .cover-logo img { height: 64px; filter: brightness(0) invert(1); }
    .cover-body { flex: 1; display: flex; flex-direction: column; justify-content: center; }
    .cover-tag {
      font-size: 10px; font-weight: 700; letter-spacing: 4px;
      text-transform: uppercase; color: var(--gold); margin-bottom: 20px;
    }
    .cover-title {
      font-size: 54px; font-weight: 900; line-height: 1.0;
      margin-bottom: 14px;
    }
    .cover-sub {
      font-size: 17px; font-weight: 300; opacity: 0.72;
      max-width: 480px; line-height: 1.65; margin-bottom: 40px;
    }
    .cover-meta { display: flex; gap: 48px; }
    .cover-meta-item label {
      display: block; font-size: 9px; font-weight: 700;
      letter-spacing: 3px; text-transform: uppercase;
      color: var(--gold); margin-bottom: 5px;
    }
    .cover-meta-item span { font-size: 15px; font-weight: 600; }
    .cover-foot {
      font-size: 11px; opacity: 0.38; display: flex;
      justify-content: space-between;
      padding-top: 28px; border-top: 1px solid rgba(255,255,255,0.1);
    }

    /* ─────────── PAGE 2 · HERO RENDER ─────────── */
    .hero-page { background: var(--dark); }
    .hero-page img { width: 100%; height: 940px; object-fit: cover; display: block; }
    .hero-cap {
      flex: 1; background: var(--green); display: flex;
      align-items: center; padding: 0 40px;
    }
    .hero-cap span {
      font-size: 10px; font-weight: 700; letter-spacing: 4px;
      text-transform: uppercase; color: rgba(255,255,255,0.45);
    }

    /* ─────────── PAGE 3 · OVERVIEW + SCOPE (1/2) ─────────── */
    .content-page { background: white; flex: 1; display: flex; flex-direction: column; }
    .section-inner { padding: 52px 64px; flex: 1; }
    .sub-header {
      background: var(--navy); padding: 14px 64px;
      font-size: 10px; font-weight: 700; letter-spacing: 4px;
      text-transform: uppercase; color: rgba(255,255,255,0.5);
    }

    .scope-list { list-style: none; margin-top: 4px; }
    .scope-list li {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 11px 0; border-bottom: 1px solid var(--border);
      font-size: 13.5px; font-weight: 600; color: #1e1e1e;
    }
    .scope-list li:last-child { border-bottom: none; }
    .scope-list li::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: var(--gold); margin-top: 6px; flex-shrink: 0;
    }
    .scope-list li span {
      font-weight: 400; color: #666; font-size: 12px;
      display: block; margin-top: 2px;
    }

    /* ─────────── PAGE 4 · SCOPE CONTINUED ─────────── */
    .continued-tag {
      background: var(--cream); padding: 12px 64px;
      font-size: 9px; font-weight: 700; letter-spacing: 3px;
      text-transform: uppercase; color: #aaa;
    }

    /* ─────────── PAGE 5 · RENDER PAIR ─────────── */
    .pair-page { background: var(--dark); flex: 1; display: grid; grid-template-rows: 1fr 1fr; }
    .pair-page img { width: 100%; height: 100%; object-fit: cover; display: block; }

    /* ─────────── PAGE 6 · EXCLUSIONS + TIMELINE ─────────── */
    .band-inner {
      background: var(--green); padding: 52px 64px; color: white;
    }
    .band-inner .title { color: white; }
    .band-inner p { font-size: 13px; color: rgba(255,255,255,0.68); line-height: 1.7; margin-bottom: 16px; }

    .not-list { list-style: none; }
    .not-list li {
      display: flex; align-items: center; gap: 12px;
      padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.08);
      font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.72);
    }
    .not-list li:last-child { border-bottom: none; }
    .not-list li::before { content: '—'; color: var(--gold); font-weight: 700; flex-shrink: 0; }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 0 36px; }

    /* Timeline */
    .timeline-wrap { padding: 44px 64px; flex: 1; background: white; }
    .timeline-steps {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 0; margin-top: 28px; position: relative;
    }
    .timeline-steps::before {
      content: ''; position: absolute;
      top: 20px; left: 22px; right: 22px; height: 2px; background: var(--border);
    }
    .timeline-step {
      display: flex; flex-direction: column; align-items: center;
      text-align: center; gap: 12px; position: relative; z-index: 1;
    }
    .step-dot {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--gold); display: flex; align-items: center;
      justify-content: center; font-size: 14px; font-weight: 900; color: var(--navy);
    }
    .step-label strong {
      display: block; font-size: 10px; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase; color: var(--green); margin-bottom: 3px;
    }
    .step-label span { font-size: 11px; color: #666; line-height: 1.5; }

    /* ─────────── PAGE 7 · RENDER + INVESTMENT ─────────── */
    .render-strip img { width: 100%; height: 420px; object-fit: cover; display: block; }
    .invest-block {
      background: var(--navy); flex: 1;
      display: flex; flex-direction: column;
    }
    .invest-top {
      padding: 28px 56px; border-bottom: 1px solid rgba(255,255,255,0.08);
      display: flex; align-items: center; gap: 48px;
    }
    .invest-top .inv-label {
      font-size: 9px; font-weight: 700; letter-spacing: 3px;
      text-transform: uppercase; color: var(--gold); margin-bottom: 6px;
    }
    .invest-total { font-size: 52px; font-weight: 900; color: white; line-height: 1; }
    .invest-note { font-size: 12px; color: rgba(255,255,255,0.38); font-weight: 500; margin-top: 6px; }
    .invest-payments { display: grid; grid-template-columns: 1fr 1fr 1fr; flex: 1; }
    .pay-block {
      padding: 24px 36px; border-right: 1px solid rgba(255,255,255,0.06);
      text-align: center; display: flex; flex-direction: column; justify-content: center;
    }
    .pay-block:last-child { border-right: none; }
    .pay-pct { font-size: 30px; font-weight: 900; color: var(--gold); margin-bottom: 6px; }
    .pay-phase { font-size: 9px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 6px; }
    .pay-detail { font-size: 11px; color: rgba(255,255,255,0.28); line-height: 1.5; }

    /* ─────────── PAGE 8 · TERMS + SIGNATURE ─────────── */
    .terms-wrap { padding: 44px 64px; }
    .terms-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 16px; }
    .terms-card {
      background: white; border: 1px solid var(--border);
      border-top: 3px solid var(--gold); border-radius: 4px; padding: 24px 28px;
    }
    .terms-card h3 {
      font-size: 9px; font-weight: 700; letter-spacing: 3px;
      text-transform: uppercase; color: var(--green); margin-bottom: 12px;
    }
    .terms-card p, .terms-card li { font-size: 12px; color: #555; line-height: 1.65; }
    .terms-card ul { list-style: none; }
    .terms-card ul li { padding: 5px 0; border-bottom: 1px solid #f0ece4; }
    .terms-card ul li:last-child { border-bottom: none; }
    .terms-card ul li::before { content: '→ '; color: var(--gold); font-weight: 700; }

    .sig-wrap {
      background: var(--green); flex: 1; padding: 36px 64px;
      display: flex; flex-direction: column;
    }
    .sig-wrap .label { color: var(--gold); }
    .sig-wrap .title { color: white; margin-bottom: 8px; }
    .sig-wrap > p {
      font-size: 12px; color: rgba(255,255,255,0.55);
      max-width: 560px; line-height: 1.7; margin-bottom: 28px;
    }
    .sig-box {
      background: white; border-radius: 4px; padding: 36px 44px; flex: 1;
    }
    .sig-box .label { color: var(--green); margin-bottom: 20px; }
    .sig-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px 48px; }
    .sig-field label {
      display: block; font-size: 9px; font-weight: 700;
      letter-spacing: 3px; text-transform: uppercase; color: var(--green); margin-bottom: 10px;
    }
    .sig-line {
      border-bottom: 2px solid var(--border); height: 40px; position: relative;
    }
    .sig-line::before {
      content: 'X'; position: absolute; bottom: 8px; left: 0;
      font-size: 11px; font-weight: 700; color: #ccc;
    }

    /* ─────────── FOOTER STRIP (last page) ─────────── */
    .foot-strip {
      background: var(--dark); padding: 16px 64px; text-align: center;
    }
    .foot-strip p {
      font-size: 10px; color: rgba(255,255,255,0.25);
      letter-spacing: 0.05em; line-height: 1.9;
    }
    .foot-strip strong { color: rgba(255,255,255,0.45); }
  </style>
</head>
<body>

<!-- ══════════════════════════════════════════════════════════
     PAGE 1 · COVER
══════════════════════════════════════════════════════════ -->
<div class="page">
  <div class="cover">
    <div class="cover-logo">
      <img src="./logo.png" alt="Timberline Build Co" />
    </div>

    <div class="cover-body">
      <div class="gold-bar"></div>
      <div class="cover-tag">Bathroom Remodel Proposal</div>
      <div class="cover-title">609 E Avenida<br>San Juan</div>
      <div class="cover-sub">Full bathroom renovation — labor &amp; installation.<br>All finish materials provided by client.</div>
      <div class="cover-meta">
        <div class="cover-meta-item">
          <label>Prepared For</label>
          <span>Bob</span>
        </div>
        <div class="cover-meta-item">
          <label>Date</label>
          <span>May 2026</span>
        </div>
        <div class="cover-meta-item">
          <label>Total Investment</label>
          <span>$17,570</span>
        </div>
        <div class="cover-meta-item">
          <label>Contact</label>
          <span>949-229-1692</span>
        </div>
      </div>
    </div>

    <div class="cover-foot">
      <span>Timberline Build Co &nbsp;·&nbsp; CSLB #1136140 &nbsp;·&nbsp; Orange County, CA</span>
      <span>timberlinebuild.co</span>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PAGE 2 · HERO RENDER
══════════════════════════════════════════════════════════ -->
<div class="page hero-page">
  <img src="./render-1.png" alt="Bathroom render" style="width:100%;height:980px;object-fit:cover;display:block;" />
  <div class="hero-cap">
    <span>Timberline Build Co &nbsp;·&nbsp; Sample Bathroom Render &nbsp;·&nbsp; 609 E Avenida San Juan</span>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PAGE 3 · PROJECT OVERVIEW + SCOPE (items 1–8)
══════════════════════════════════════════════════════════ -->
<div class="page content-page">
  <div class="section-inner">
    <div class="label">Project Overview</div>
    <div class="title">What We're Building</div>
    <p style="font-size:13.5px;color:#444;line-height:1.75;max-width:680px;margin-bottom:10px;">
      Full bathroom remodel at 609 E Avenida San Juan, San Clemente. Complete demolition, enclosed cave-style shower construction, full tile installation, updated electrical and plumbing, vanity and medicine cabinet installation, exhaust fan, door replacement, and ceiling repaint.
    </p>
    <p style="font-size:13px;color:#888;line-height:1.7;max-width:680px;margin-bottom:28px;">
      <strong style="color:#555;">All finish materials are provided by the client</strong> — tile, vanity, medicine cabinet, countertop slab, sconce fixtures, and ceiling paint. Timberline supplies all labor, rough materials, and installation expertise.
    </p>

    <div class="label" style="margin-top:4px;">Scope of Work</div>
    <div class="title" style="font-size:22px;">What's Included</div>

    <ul class="scope-list">
      <li>Full Demolition<span>Complete tear-out of all existing finishes, fixtures, and flooring. Removal of partition wall between vanity and toilet area.</span></li>
      <li>Shower Wall Framing<span>Frame and build fully enclosed shower walls — cave-style design, no glass enclosure required.</span></li>
      <li>Drywall &amp; Wall Prep<span>Patch and repair all non-wet areas after demo. Hang new drywall as needed.</span></li>
      <li>Cement Board + RedGuard Waterproofing<span>Install cement board and full RedGuard membrane in all wet zones (shower walls, shower floor area).</span></li>
      <li>Hot Mop — Shower Pan<span>Professional hot mop of shower pan for complete waterproof integrity prior to tile installation.</span></li>
      <li>Tile Installation — All Areas (Labor Only)<span>Set, grout, and finish tile on all bathroom walls and floor. Client supplies all tile.</span></li>
      <li>Plumbing — Shower Valve Installation<span>Supply and set shower valve with proper water connections.</span></li>
      <li>Plumbing — Toilet Drain Relocation<span>Relocate toilet drain to accommodate new layout.</span></li>
    </ul>
  </div>
  <div class="sub-header">Scope of Work · Continued on next page</div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PAGE 4 · SCOPE CONTINUED (items 9–16)
══════════════════════════════════════════════════════════ -->
<div class="page content-page" style="background:var(--light);">
  <div class="continued-tag">Scope of Work — Continued</div>
  <div class="section-inner">
    <ul class="scope-list">
      <li>Plumbing — Set Toilet &amp; Vanity Reconnect<span>Set toilet in new location, reconnect all vanity plumbing.</span></li>
      <li>Electrical — 4 Recessed Can Lights<span>Supply and install four recessed LED cans with proper electrical runs and switches.</span></li>
      <li>Electrical — 2 Sconces (Wire &amp; Install)<span>Run wire and install two vanity sconces. Client supplies fixtures.</span></li>
      <li>Electrical — Exhaust Vent Fan<span>Supply and install new exhaust fan with exterior venting. No existing fan in this bathroom.</span></li>
      <li>Vanity Installation (Labor Only)<span>Install client-supplied vanity, make plumbing connections.</span></li>
      <li>Medicine Cabinet — Frame &amp; Install (Labor Only)<span>Frame recessed opening and install client-supplied medicine cabinet over sink.</span></li>
      <li>Ceiling Repaint (Labor Only)<span>Prep and apply finish coat to bathroom ceiling. Client supplies paint.</span></li>
      <li>Door &amp; Casing Replacement — 28" RH<span>Install 6-panel door with generic casing. Includes door, hardware, and casing installation.</span></li>
    </ul>
  </div>
  <div class="sub-header" style="background:var(--green);">16 line items total &nbsp;·&nbsp; All labor &amp; installation included</div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PAGE 5 · RENDER PAIR
══════════════════════════════════════════════════════════ -->
<div class="page" style="background:var(--dark);display:flex;flex-direction:column;">
  <img src="./render-2.png" alt="Bathroom tile render" style="width:100%;height:528px;object-fit:cover;display:block;" />
  <img src="./render-3.png" alt="Bathroom vanity render" style="width:100%;height:528px;object-fit:cover;display:block;" />
</div>


<!-- ══════════════════════════════════════════════════════════
     PAGE 6 · EXCLUSIONS + TIMELINE
══════════════════════════════════════════════════════════ -->
<div class="page content-page">
  <div class="band-inner">
    <div class="label">Exclusions</div>
    <div class="title title-light" style="font-size:22px;margin-bottom:12px;">What's Not Included</div>
    <p>Client is responsible for sourcing and delivering all finish materials prior to scheduled installation dates.</p>
    <ul class="not-list two-col" style="margin-top:8px;">
      <li>All tile (client supplied)</li>
      <li>Vanity unit (client supplied)</li>
      <li>Medicine cabinet (client supplied)</li>
      <li>Countertop slab (client supplied)</li>
      <li>Sconce fixtures (client supplied)</li>
      <li>Ceiling paint (client supplied)</li>
      <li>Baseboard (not in scope)</li>
      <li>Countertop fabrication or delivery</li>
      <li>Permits — consult city requirements</li>
      <li>Furniture moving or storage</li>
    </ul>
  </div>

  <div class="timeline-wrap">
    <div class="label">Project Schedule</div>
    <div class="title" style="font-size:22px;margin-bottom:6px;">Estimated Timeline</div>
    <p style="font-size:13px;color:#666;line-height:1.6;">3–4 weeks from start date, pending material availability on-site and any permit requirements.</p>
    <div class="timeline-steps">
      <div class="timeline-step">
        <div class="step-dot">1</div>
        <div class="step-label">
          <strong>Sign &amp; Deposit</strong>
          <span>Contract signed,<br>$1,000 secures start date</span>
        </div>
      </div>
      <div class="timeline-step">
        <div class="step-dot">2</div>
        <div class="step-label">
          <strong>Week 1–2</strong>
          <span>Demo, framing,<br>rough plumbing &amp; electrical</span>
        </div>
      </div>
      <div class="timeline-step">
        <div class="step-dot">3</div>
        <div class="step-label">
          <strong>Week 2–3</strong>
          <span>Hot mop, cement board,<br>RedGuard, tile install</span>
        </div>
      </div>
      <div class="timeline-step">
        <div class="step-dot">4</div>
        <div class="step-label">
          <strong>Week 3–4</strong>
          <span>Fixtures, vanity, lights,<br>door, punch list</span>
        </div>
      </div>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PAGE 7 · RENDER + INVESTMENT
══════════════════════════════════════════════════════════ -->
<div class="page" style="display:flex;flex-direction:column;">
  <img src="./render-4.png" alt="Modern bathroom render" style="width:100%;height:420px;object-fit:cover;display:block;" />
  <div class="invest-block">
    <div class="invest-top">
      <div>
        <div class="inv-label">Total Project Investment</div>
        <div class="invest-total">$17,570</div>
        <div class="invest-note">Labor &amp; installation only &nbsp;·&nbsp; All finish materials provided by client</div>
      </div>
    </div>
    <div class="invest-payments">
      <div class="pay-block">
        <div class="pay-pct">$1,000</div>
        <div class="pay-phase">At Signing</div>
        <div class="pay-detail">Secures your start date<br>per CA contractor law</div>
      </div>
      <div class="pay-block">
        <div class="pay-pct">40%</div>
        <div class="pay-phase">At Midpoint</div>
        <div class="pay-detail">Rough work complete,<br>inspections passed</div>
      </div>
      <div class="pay-block">
        <div class="pay-pct">30%</div>
        <div class="pay-phase">At Completion</div>
        <div class="pay-detail">Final walkthrough &amp;<br>punch list sign-off</div>
      </div>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PAGE 8 · TERMS + SIGNATURE
══════════════════════════════════════════════════════════ -->
<div class="page content-page">
  <div class="terms-wrap">
    <div class="label">Terms &amp; Warranty</div>
    <div class="title" style="font-size:22px;margin-bottom:4px;">Our Commitment</div>
    <div class="terms-grid">
      <div class="terms-card">
        <h3>Warranty</h3>
        <p>Timberline Build Co warrants all labor for <strong>1 year</strong> from project completion. Manufacturer warranties apply to all materials and fixtures supplied by Timberline. Client-supplied materials carry their own manufacturer warranty.</p>
      </div>
      <div class="terms-card">
        <h3>Terms &amp; Conditions</h3>
        <ul>
          <li>All change orders require written approval before work begins</li>
          <li>Client materials must be on-site before scheduled installation</li>
          <li>Scope changes may affect timeline and investment</li>
          <li>Lien waiver provided at final payment</li>
          <li>Licensed &amp; insured — CSLB #1136140</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="sig-wrap">
    <div class="label">Authorization</div>
    <div class="title title-light" style="font-size:22px;">Ready to Get Started?</div>
    <p>By signing below, you authorize Timberline Build Co to proceed with the scope of work as described in this proposal at the total investment stated. All change orders require written approval. Client-supplied materials must be on-site prior to scheduled installation.</p>
    <div class="sig-box">
      <div class="label">Signatures</div>
      <div class="sig-grid">
        <div class="sig-field">
          <label>Client Signature</label>
          <div class="sig-line"></div>
        </div>
        <div class="sig-field">
          <label>Date</label>
          <div class="sig-line"></div>
        </div>
        <div class="sig-field">
          <label>Printed Name</label>
